{
  "name": "mainqa",
  "version": "1.0.0",
  "description": " проект по автоматизации тестирования",
  "scripts": {
    "test": "playwright test",
    "test:ui": "playwright test tests/ui",
    "test:api": "playwright test tests/api",
    "test:all": "playwright test",
    "allure:generate": "allure generate allure-results --clean -o allure-report",
    "allure:open": "allure open allure-report",
    "allure:clear": "rm -rf allure-results allure-report",
    "allure:history": "cp -r allure-history/* allure-report/history/ || true",
    "docker:build": "docker build -t diplom-automation:latest .",
    "docker:run": "docker run --rm -v $(pwd)/allure-results:/app/allure-results diplom-automation:latest"
  },
  "keywords": ["automation", "playwright", "allure", "diplom"],
  "author": "Your Name",
  "license": "ISC",
  "devDependencies": {
    "@playwright/test": "^1.40.0",
    "@faker-js/faker": "^8.3.1",
    "allure-playwright": "^2.10.0",
    "axios": "^1.6.2"
  }
}